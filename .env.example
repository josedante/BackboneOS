# Django Backend Configuration
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
DATABASE_NAME=mydatabase
DATABASE_USER=myuser
DATABASE_PASSWORD=mypassword
DATABASE_HOST=db
DATABASE_PORT=5432

# Caching Configuration
DJANGO_REDIS_URL=redis://redis:6379/1

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
# Celery Result Backend
CELERY_RESULT_BACKEND=redis://redis:6379/2

# CORS Configuration (comma-separated for production)
# Used by external API clients and integrations — operator CRM is same-origin Django HTML.
# Example: CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=

# CSRF trusted origins (comma-separated). In dev, defaults to the orb.local backend URL.
# In production, set explicitly: CSRF_TRUSTED_ORIGINS=https://api.mysite.com
CSRF_TRUSTED_ORIGINS=https://backend.proyecto-opensource.orb.local

# Auth cookie settings
# Development default: None (cross-origin, requires HTTPS — orb.local uses self-signed certs)
# Production default: Lax (same registered domain, e.g. app.mysite.com + api.mysite.com)
COOKIE_SAMESITE=None
COOKIE_SECURE=True
